{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@skoolpath/shared": [
        "packages/shared/src"
      ],
      "@skoolpath/shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}
